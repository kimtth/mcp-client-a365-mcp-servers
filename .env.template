# --- MCP / Agent 365 Auth ---
# MCP_CLIENT_ID: Your public client app registration (for device-code auth with all MCP scopes)
MCP_CLIENT_ID=00000000-0000-0000-0000-000000000000
MCP_TENANT_ID=00000000-0000-0000-0000-000000000000
MCP_AUTH_MODE=device-code

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_AUTH_MODE=azure-cli
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# --- Bridge ---
BRIDGE_TYPE=python

